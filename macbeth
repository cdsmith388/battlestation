        }).join(''):`<div class="mini">No candidates yet. Drag a name here, or add one below.</div>`}
        <div class="add-q">
          <select data-addcand>
            <option value="">Add a candidate...</option>
            ${state.actors.filter(a=>!c.candidates.includes(a.id)).map(a=>`<option value="${a.id}">${esc(a.name)}</option>`).join('')}
          </select>
        </div>
      </div>
      <div class="field">
        <label class="field-label">Notes on the role</label>
        <textarea data-char-notes placeholder="Tone, age, what this role demands.">${esc(c.notes||'')}</textarea>
      </div>
      <div class="field">
        <label class="field-label">Questions</label>
        <div class="q-list">${(c.questions||[]).map((q,i)=>`<div class="q-item"><span class="qtext">${esc(q)}</span><button class="qx" data-delq="${i}" title="Remove">&times;</button></div>`).join('')}</div>
        <div class="add-q">
          <input type="text" data-newq placeholder="Who can carry the sleepwalk scene?">
          <button class="icon-btn" data-addq title="Add question">+</button>
        </div>
      </div>`;
  }
}

/* swatch selection state for new labels */
let newLabelColor=SWATCHES[0];

/* ---------- drawer events (delegated) ---------- */
document.getElementById('drawer').addEventListener('click',e=>{
  const t=e.target;
  if(t.closest('[data-close]')){closeDrawer();return;}
  const tl=t.closest('[data-toggle-label]');if(tl){toggleLabel(openId,tl.dataset.toggleLabel);return;}
  if(t.closest('[data-addlabel]')){
    const inp=document.querySelector('[data-newlabel]');const nm=inp.value.trim();
    if(nm){state.labels.push({id:uid(),name:nm,color:newLabelColor});if(openKind==='actor'){const a=actor(openId);a.labels=a.labels||[];}commit();}
    return;
  }
  const sw=t.closest('[data-sw]');if(sw){newLabelColor=sw.dataset.sw;document.querySelectorAll('[data-swatches] .sw').forEach(x=>x.classList.remove('sel'));sw.classList.add('sel');return;}
  const jc=t.closest('[data-jumpchar]');if(jc){openCharDrawer(jc.dataset.jumpchar);return;}
  if(t.closest('[data-delete-actor]')){if(confirm('Banish this name from the casting entirely?')){deleteActor(openId);closeDrawer();}return;}
  const sc=t.closest('[data-setcast]');if(sc){toggleCast(openId,sc.dataset.setcast);return;}
  const vd=t.closest('[data-verdict]');if(vd){const p=vd.dataset.verdict.split('|');setVerdict(openId,p[0],p[1]);return;}
  const cp=t.closest('[data-cert]');if(cp){const p=cp.dataset.cert.split('|');setCertainty(openId,p[0],+p[1]);return;}
  const rc=t.closest('[data-removecand]');if(rc){unassign(rc.dataset.removecand,openId);return;}
  const dq=t.closest('[data-delq]');if(dq){const c=char(openId);c.questions.splice(+dq.dataset.delq,1);commit();return;}
  if(t.closest('[data-addq]')){const inp=document.querySelector('[data-newq]');const v=inp.value.trim();if(v){const c=char(openId);c.questions=c.questions||[];c.questions.push(v);commit();}return;}
});
document.getElementById('drawer').addEventListener('input',e=>{
  const t=e.target;
  if(t.matches('[data-actor-name]')){actor(openId).name=t.value;save();renderRoster();renderStage();}
  else if(t.matches('[data-actor-notes]')){actor(openId).notes=t.value;save();}
  else if(t.matches('[data-char-notes]')){char(openId).notes=t.value;save();renderStage();}
});
document.getElementById('drawer').addEventListener('change',e=>{
  const t=e.target;
  if(t.matches('[data-addrole]')&&t.value){assignActor(openId,t.value,null);}
  else if(t.matches('[data-addcand]')&&t.value){assignActor(t.value,openId,null);}
});
document.getElementById('drawer').addEventListener('keydown',e=>{
  if(e.key==='Enter'){
    if(e.target.matches('[data-newq]')){e.preventDefault();const v=e.target.value.trim();if(v){const c=char(openId);c.questions=c.questions||[];c.questions.push(v);commit();}}
    if(e.target.matches('[data-newlabel]')){e.preventDefault();const nm=e.target.value.trim();if(nm){state.labels.push({id:uid(),name:nm,color:newLabelColor});commit();}}
  }
});
document.getElementById('scrim').addEventListener('click',closeDrawer);
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeDrawer();});

/* ---------- add name ---------- */
function doAdd(){const inp=document.getElementById('nameInput');const a=addActor(inp.value);if(a){inp.value='';inp.focus();}}
document.getElementById('addBtn').addEventListener('click',doAdd);
document.getElementById('nameInput').addEventListener('keydown',e=>{if(e.key==='Enter')doAdd();});
document.getElementById('addTopBtn').addEventListener('click',()=>{document.getElementById('nameInput').focus();window.scrollTo({top:0,behavior:'smooth'});});

/* ---------- export / import / reset ---------- */
document.getElementById('exportBtn').addEventListener('click',()=>{
  const blob=new Blob([JSON.stringify(state,null,2)],{type:'application/json'});
  const url=URL.createObjectURL(blob);const a=document.createElement('a');
  a.href=url;a.download='macbeth-casting.json';a.click();URL.revokeObjectURL(url);
});
document.getElementById('importInput').addEventListener('change',e=>{
  const f=e.target.files[0];if(!f)return;
  const r=new FileReader();
  r.onload=()=>{try{const data=JSON.parse(r.result);if(data&&data.characters&&data.actors){state=normalize(data);commit();}else alert('That file does not look like a casting sheet.');}catch(err){alert('Could not read that file.');}};
  r.readAsText(f);e.target.value='';
});
document.getElementById('resetBtn').addEventListener('click',()=>{
  if(confirm('Clear all names and casting, and restore the empty Macbeth cast? This cannot be undone.')){state=defaultState();commit();}
});

/* ---------- click to open drawers (delegated, non-drag) ---------- */
function bindOpen(){
  document.getElementById('rosterList').addEventListener('click',e=>{if(suppressClick)return;const el=e.target.closest('[data-actor]');if(el)openActorDrawer(el.dataset.actor);});
  document.getElementById('rosterList').addEventListener('keydown',e=>{const el=e.target.closest('[data-actor]');if(el&&(e.key==='Enter'||e.key===' ')){e.preventDefault();openActorDrawer(el.dataset.actor);}});
  document.getElementById('stage').addEventListener('click',e=>{
    if(suppressClick)return;
    if(e.target.closest('[data-seal]')){const v=e.target.closest('[data-seal]').dataset.seal.split('|');toggleCast(v[0],v[1]);return;}
    const chip=e.target.closest('[data-chip]');if(chip){openActorDrawer(chip.dataset.chip);return;}
    const c=e.target.closest('[data-char-id]');if(c)openCharDrawer(c.dataset.charId);
  });
  document.getElementById('stage').addEventListener('keydown',e=>{const c=e.target.closest('[data-char-id]');if(c&&(e.key==='Enter'||e.key===' ')){e.preventDefault();openCharDrawer(c.dataset.charId);}});
}

/* ---------- pointer drag ---------- */
let drag=null,suppressClick=false,lastDrop=null;
function startDrag(e){
  if(e.button!==undefined&&e.button!==0&&e.pointerType==='mouse')return;
  const chip=e.target.closest('[data-chip]');
  const act=e.target.closest('[data-actor]');
  if(e.target.closest('[data-seal]'))return;
  let payload=null,srcEl=null;
  if(chip){payload={actorId:chip.dataset.chip,fromCharId:chip.dataset.from};srcEl=chip;}
  else if(act){payload={actorId:act.dataset.actor,fromCharId:null};srcEl=act;}
  if(!payload)return;
  drag={...payload,startX:e.clientX,startY:e.clientY,active:false,ghost:null,srcEl};
  window.addEventListener('pointermove',moveDrag);
  window.addEventListener('pointerup',endDrag);
}
function moveDrag(e){
  if(!drag)return;
  const dx=e.clientX-drag.startX,dy=e.clientY-drag.startY;
  if(!drag.active){
    if(Math.hypot(dx,dy)<7)return;
    drag.active=true;suppressClick=true;document.body.classList.add('dragging');
    drag.srcEl.classList.add('dragging-src');
    const g=document.createElement('div');g.className='ghost';
    g.textContent=actor(drag.actorId)?.name||'';document.body.appendChild(g);drag.ghost=g;
  }
  drag.ghost.style.left=e.clientX+'px';drag.ghost.style.top=e.clientY+'px';
  // edge autoscroll
  const m=70;if(e.clientY<m)window.scrollBy(0,-14);else if(e.clientY>window.innerHeight-m)window.scrollBy(0,14);
  highlight(e.clientX,e.clientY);
}
function highlight(x,y){
  if(drag.ghost)drag.ghost.style.display='none';
  const el=document.elementFromPoint(x,y);
  if(drag.ghost)drag.ghost.style.display='';
  const drop=el?el.closest('[data-drop]'):null;
  if(drop!==lastDrop){
    if(lastDrop&&lastDrop.dataset.drop==='char')lastDrop.classList.remove('drop-active');
    if(drop&&drop.dataset.drop==='char')drop.classList.add('drop-active');
    lastDrop=drop;
  }
}
function endDrag(e){
  window.removeEventListener('pointermove',moveDrag);
  window.removeEventListener('pointerup',endDrag);
  if(drag&&drag.active){
    if(drag.ghost)drag.ghost.style.display='none';
    const el=document.elementFromPoint(e.clientX,e.clientY);
    const drop=el?el.closest('[data-drop]'):null;
    if(drop){
      if(drop.dataset.drop==='char'){
        const toId=drop.dataset.charId;
        if(toId!==drag.fromCharId)assignActor(drag.actorId,toId,drag.fromCharId);
      } else if(drop.dataset.drop==='roster'){
        if(drag.fromCharId)unassign(drag.actorId,drag.fromCharId);
      }
    }
    if(drag.ghost)drag.ghost.remove();
    if(lastDrop&&lastDrop.dataset.drop==='char')lastDrop.classList.remove('drop-active');
    lastDrop=null;
    document.body.classList.remove('dragging');
    if(drag.srcEl)drag.srcEl.classList.remove('dragging-src');
    setTimeout(()=>{suppressClick=false;},30);
  } else {
    suppressClick=false;
  }
  drag=null;
}
document.getElementById('rosterList').addEventListener('pointerdown',startDrag);
document.getElementById('stage').addEventListener('pointerdown',startDrag);

bindOpen();
render();
</script>
