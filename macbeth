function defaultState(){
  const characters = [];
  DEFAULT_CHARS.forEach(([group,rows])=>{
    rows.forEach(([name,desc])=>{
      characters.push({id:uid(),group,name,desc,candidates:[],castId:null,notes:'',questions:[]});
    });
  });
  return {
    actors:[],
    labels:[
      {id:uid(),name:'Callback',color:'#c9a24b'},
      {id:uid(),name:'Strong voice',color:'#a01421'},
      {id:uid(),name:'Movement',color:'#7a4a8a'},
    ],
    characters,
  };
}

const KEY='macbeth-casting-v1';
let state = normalize(load() || defaultState());

function normalize(s){
  if(!s.actors)s.actors=[];if(!s.labels)s.labels=[];if(!s.characters)s.characters=[];
  s.actors.forEach(a=>{if(!a.labels)a.labels=[];if(a.notes==null)a.notes='';});
  s.characters.forEach(c=>{if(!c.meta)c.meta={};if(!c.questions)c.questions=[];if(c.notes==null)c.notes='';if(!c.candidates)c.candidates=[];if(c.castId===undefined)c.castId=null;});
  return s;
}

function load(){
  try{const r=localStorage.getItem(KEY);return r?JSON.parse(r):null;}catch(e){return null;}
}
function save(){
  try{localStorage.setItem(KEY,JSON.stringify(state));}catch(e){}
}

function esc(s){return String(s).replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));}
function actor(id){return state.actors.find(a=>a.id===id);}
function char(id){return state.characters.find(c=>c.id===id);}
function label(id){return state.labels.find(l=>l.id===id);}
function rolesFor(actorId){return state.characters.filter(c=>c.candidates.includes(actorId));}

/* ---------- mutations ---------- */
function addActor(name){
  name=name.trim();if(!name)return null;
  const a={id:uid(),name,notes:'',labels:[]};
  state.actors.push(a);commit();return a;
}
function assignActor(actorId,toCharId,fromCharId){
  if(fromCharId){
    const from=char(fromCharId);
    if(from){from.candidates=from.candidates.filter(x=>x!==actorId);if(from.castId===actorId)from.castId=null;if(from.meta)delete from.meta[actorId];}
  }
  const to=char(toCharId);
  if(to && !to.candidates.includes(actorId))to.candidates.push(actorId);
  commit();
}
function unassign(actorId,fromCharId){
  const c=char(fromCharId);if(!c)return;
  c.candidates=c.candidates.filter(x=>x!==actorId);
  if(c.castId===actorId)c.castId=null;
  if(c.meta)delete c.meta[actorId];
  commit();
}
function toggleCast(charId,actorId){
  const c=char(charId);if(!c)return;
  c.castId=c.castId===actorId?null:actorId;commit();
}
function deleteActor(actorId){
  state.actors=state.actors.filter(a=>a.id!==actorId);
  state.characters.forEach(c=>{c.candidates=c.candidates.filter(x=>x!==actorId);if(c.castId===actorId)c.castId=null;if(c.meta)delete c.meta[actorId];});
  commit();
}
function metaFor(c,actorId){if(!c.meta)c.meta={};if(!c.meta[actorId])c.meta[actorId]={verdict:null,certainty:0};return c.meta[actorId];}
function setVerdict(charId,actorId,v){const c=char(charId);if(!c)return;const m=metaFor(c,actorId);m.verdict=m.verdict===v?null:v;commit();}
function setCertainty(charId,actorId,n){const c=char(charId);if(!c)return;const m=metaFor(c,actorId);m.certainty=m.certainty===n?0:n;commit();}
function toggleLabel(actorId,labelId){
  const a=actor(actorId);if(!a)return;
  a.labels=a.labels||[];
  if(a.labels.includes(labelId))a.labels=a.labels.filter(x=>x!==labelId);
  else a.labels.push(labelId);
  commit();
}
function commit(){save();render();}

/* ---------- render ---------- */
function dotsHtml(actorId){
  const a=actor(actorId);if(!a||!a.labels||!a.labels.length)return '';
  return '<span class="dots">'+a.labels.map(lid=>{const l=label(lid);return l?`<span class="dot" style="background:${l.color}"></span>`:'';}).join('')+'</span>';
}

function renderRoster(){
  const list=document.getElementById('rosterList');
  document.getElementById('rosterCount').textContent=state.actors.length;
  if(!state.actors.length){list.innerHTML='<div class="empty-note">No one summoned yet.<br>Add a name above.</div>';return;}
  list.innerHTML=state.actors.map(a=>{
    const n=rolesFor(a.id).length;
    return `<div class="actor" data-actor="${a.id}" role="button" tabindex="0" aria-label="${esc(a.name)}">
      ${dotsHtml(a.id)}
      <span class="nm">${esc(a.name)}</span>
      ${n?`<span class="roles-badge">${n}</span>`:''}
    </div>`;
  }).join('');
}

function renderStage(){
  const stage=document.getElementById('stage');
  const groups=[];
  state.characters.forEach(c=>{if(!groups.includes(c.group))groups.push(c.group);});
  stage.innerHTML=groups.map(g=>{
    const cards=state.characters.filter(c=>c.group===g).map(c=>{
      const chips=c.candidates.map(aid=>{
        const a=actor(aid);if(!a)return '';
        const isCast=c.castId===aid;
        const m=(c.meta&&c.meta[aid])||{};
        const vcls=m.verdict?('v-'+m.verdict):'';
        const pips=m.certainty?`<span class="pips" title="Certainty ${m.certainty} of 5">${[1,2,3,4,5].map(i=>`<span class="pip ${i<=m.certainty?'on':''}"></span>`).join('')}</span>`:'';
        return `<span class="chip ${isCast?'cast':''} ${vcls}" data-chip="${aid}" data-from="${c.id}">
          <button class="seal" data-seal="${c.id}|${aid}" title="${isCast?'Unbind':'Bind in blood'}">${SEAL_SVG}</button>
          <span class="cnm">${esc(a.name)}</span>
          ${pips}
          <span class="cdots">${(a.labels||[]).map(lid=>{const l=label(lid);return l?`<span class="dot" style="background:${l.color}"></span>`:'';}).join('')}</span>
        </span>`;
      }).join('');
      const castName=c.castId?actor(c.castId)?.name:null;
      const meta=[];
      if(castName)meta.push(`<span class="tag-mini" style="color:var(--blood-bright)">&#10022; ${esc(castName)}</span>`);
      if(c.questions&&c.questions.length)meta.push(`<span class="tag-mini">? ${c.questions.length}</span>`);
      if(c.notes&&c.notes.trim())meta.push(`<span class="tag-mini">notes</span>`);
      return `<article class="char" data-drop="char" data-char-id="${c.id}" role="button" tabindex="0">
        <div class="char-name">${esc(c.name)}</div>
        <div class="char-desc">${esc(c.desc||'')}</div>
        ${(()=>{const p=presence(c.name);return p?`<div class="presence"><div class="pbar"><div class="pbar-fill" style="width:${p.barW}%"></div></div><div class="pstat">${p.lines} lines &middot; ${p.pctLabel} of play</div></div>`:'';})()}
        ${meta.length?`<div class="char-meta">${meta.join('')}</div>`:''}
        <div class="candidates">${chips}</div>
      </article>`;
    }).join('');
    return `<section class="group"><h2 class="group-title">${esc(g)}</h2><div class="char-grid">${cards}</div></section>`;
  }).join('');
}

function renderProgress(){
  const total=state.characters.length;
  const castN=state.characters.filter(c=>c.castId).length;
  const pct=total?Math.round(castN/total*100):0;
  document.getElementById('barFill').style.width=pct+'%';
  document.getElementById('bandPct').textContent=pct+'%';
  document.getElementById('bandCount').textContent=castN+' / '+total+' roles cast';
  let def=0,may=0,no=0;
  state.characters.forEach(c=>{const m=c.meta||{};Object.keys(m).forEach(k=>{const v=m[k].verdict;if(v==='definitely')def++;else if(v==='maybe')may++;else if(v==='no')no++;});});
  document.getElementById('tDef').textContent=def;
  document.getElementById('tMay').textContent=may;
  document.getElementById('tNo').textContent=no;
}

function render(){renderProgress();renderRoster();renderStage();if(openKind)renderDrawer();}

/* ---------- drawer ---------- */
let openKind=null,openId=null;
function openActorDrawer(id){openKind='actor';openId=id;renderDrawer();showDrawer();}
function openCharDrawer(id){openKind='char';openId=id;renderDrawer();showDrawer();}
function showDrawer(){document.getElementById('drawer').classList.add('open');document.getElementById('scrim').classList.add('open');}
function closeDrawer(){openKind=null;openId=null;document.getElementById('drawer').classList.remove('open');document.getElementById('scrim').classList.remove('open');}

function renderDrawer(){
  const d=document.getElementById('drawer');
  if(openKind==='actor'){
    const a=actor(openId);if(!a){closeDrawer();return;}
    const roles=rolesFor(a.id);
    d.innerHTML=`<button class="x" data-close>&times;</button>
      <div class="drawer-eyebrow">The Summoned</div>
      <h2>${esc(a.name)}</h2>
      <div class="field">
        <label class="field-label">Name</label>
        <input type="text" data-actor-name value="${esc(a.name)}">
      </div>
      <div class="field">
        <label class="field-label">Marks</label>
        <div class="label-pool">${state.labels.map(l=>{
          const on=(a.labels||[]).includes(l.id);
          return `<span class="lbl ${on?'on':''}" data-toggle-label="${l.id}" style="${on?`background:${l.color}`:''}">
            ${on?'':`<span class="swatch" style="background:${l.color}"></span>`}${esc(l.name)}</span>`;
        }).join('')}</div>
        <div class="newlabel">
          <input type="text" data-newlabel placeholder="New mark" maxlength="22">
          <button class="icon-btn" data-addlabel title="Add mark">+</button>
        </div>
        <div class="swatch-row" data-swatches>${SWATCHES.map((c,i)=>`<span class="sw ${i===0?'sel':''}" data-sw="${c}" style="background:${c}"></span>`).join('')}</div>
      </div>
      <div class="field">
        <label class="field-label">Notes</label>
        <textarea data-actor-notes placeholder="Range, presence, instincts, anything you want to remember.">${esc(a.notes||'')}</textarea>
      </div>
      <div class="field">
        <label class="field-label">Considered for</label>
        ${roles.length?`<div class="role-list">${roles.map(c=>{
          const cast=c.castId===a.id;
          return `<div class="role-row ${cast?'is-cast':''}"><span class="rg">${esc(c.name)}${cast?' &#10022;':''}</span>
            <button class="btn" data-jumpchar="${c.id}" style="padding:4px 9px">Open</button></div>`;
        }).join('')}</div>`:`<div class="mini">Not yet placed in any role. Drag this name onto a role, or add one below.</div>`}
        <div class="add-q">
          <select data-addrole>
            <option value="">Add to a role...</option>
            ${state.characters.filter(c=>!c.candidates.includes(a.id)).map(c=>`<option value="${c.id}">${esc(c.name)}</option>`).join('')}
          </select>
        </div>
      </div>
      <div class="danger">
        <button class="btn del" data-delete-actor>Banish this name</button>
      </div>`;
  } else if(openKind==='char'){
    const c=char(openId);if(!c){closeDrawer();return;}
    d.innerHTML=`<button class="x" data-close>&times;</button>
      <div class="drawer-eyebrow">${esc(c.group)}</div>
      <h2>${esc(c.name)}</h2>
      <div class="char-desc" style="margin-top:2px">${esc(c.desc||'')}</div>
      ${(()=>{const p=presence(c.name);return p?`<div class="drawer-presence"><div class="pbar"><div class="pbar-fill" style="width:${p.barW}%"></div></div><div class="pstat-full">Approx ${p.lines} lines, about ${p.pctLabel} of the play. Counts per OpenSourceShakespeare and vary by edition.</div></div>`:'';})()}
      <div class="field">
        <label class="field-label">Candidates</label>
        ${c.candidates.length?c.candidates.map(aid=>{
          const a=actor(aid);if(!a)return '';
          const cast=c.castId===aid;
          const m=(c.meta&&c.meta[aid])||{};
          return `<div class="cand-block">
            <div class="cand-head">
              <span class="cn">${esc(a.name)}${cast?' <span style="color:var(--blood-bright)">&#10022;</span>':''}</span>
              <button class="btn" data-setcast="${aid}" style="padding:4px 9px">${cast?'Sealed':'Seal'}</button>
              <button class="btn" data-removecand="${aid}" style="padding:4px 9px">Remove</button>
            </div>
            <div class="verdict-row">
              <button class="vbtn ${m.verdict==='definitely'?'on-definitely':''}" data-verdict="${aid}|definitely">Definitely</button>
              <button class="vbtn ${m.verdict==='maybe'?'on-maybe':''}" data-verdict="${aid}|maybe">Maybe</button>
              <button class="vbtn ${m.verdict==='no'?'on-no':''}" data-verdict="${aid}|no">No</button>
            </div>
            <div class="cert-row">
              <span class="cert-label">Certain</span>
              <div class="cert-pips">${[1,2,3,4,5].map(i=>`<span class="cpip ${m.certainty>=i?'on':''}" data-cert="${aid}|${i}">${i}</span>`).join('')}</div>
            </div>
